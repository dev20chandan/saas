generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id         String    @id @default(uuid())
  name       String
  code       String    @unique
  type       String    @default("CBSE")
  city       String
  state      String
  address    String?
  principal  String
  plan       String    @default("Basic")
  status     String    @default("Trial")
  students   Int       @default(0)
  teachers   Int       @default(0)
  email      String
  phone      String
  operator   String?
  themeColor String    @default("#4F46E5")
  joined     DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  users      User[]
  tickets    Ticket[]
  activities Activity[]
  studentRecords Student[]
}

model Admin {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  role       String    @default("Admin")
  schoolId   String    @default("ALL")
  schoolName String?   
  operator   String?
  status     String    @default("Active")
  phone      String?
  lastLogin  DateTime?
  settings   Json      @default("{}")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  role       String    @default("Teacher")
  schoolId   String    
  schoolUuid String?   
  schoolName String?   
  operator   String?
  status     String    @default("Active")
  phone      String?
  lastLogin  DateTime?
  settings   Json      @default("{}")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  school     School?   @relation(fields: [schoolUuid], references: [id])
  tickets    Ticket[]  @relation("SubmitterTickets")
}

model Ticket {
  id          String   @id @default(uuid())
  ticketId    String   @unique
  subject     String
  schoolId    String
  submitterId String
  priority    String   @default("Low")
  status      String   @default("Open")
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School   @relation(fields: [schoolId], references: [id])
  submitter   User     @relation("SubmitterTickets", fields: [submitterId], references: [id])
}

model Activity {
  id         String   @id @default(uuid())
  type       String
  text       String
  color      String
  schoolId   String   @default("ALL")
  schoolUuid String?  
  time       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  school     School?  @relation(fields: [schoolUuid], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  eventId   String   @unique
  user      String
  role      String
  action    String
  resource  String
  status    String
  ipAddress String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id             String       @id @default(uuid())
  name           String
  email          String?      @unique
  password       String?
  phone          String?
  status         String       @default("Active")
  schoolId       String
  schoolUuid     String?
  schoolName     String?
  rollNumber     String
  className      String
  guardianName   String
  dob            String?
  gender         String       @default("Male")
  bloodGroup     String?      @default("O+")
  feeStatus      String       @default("Pending")
  attendanceRate Int          @default(95)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  school         School?      @relation(fields: [schoolUuid], references: [id])
  attendances    Attendance[]
}

model Attendance {
  id         String   @id @default(uuid())
  studentId  String
  status     String
  date       String
  schoolId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
